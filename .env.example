# ==================== 贪吃蛇 - 环境配置 ====================
# 使用方法: cp .env.example .env && 修改 DB_PASSWORD 和 JWT_SECRET

# ==================== 必需配置 ====================
# 数据库密码（必填，生产环境请使用强密码）
DB_PASSWORD=your-secure-db-password

# JWT 密钥（必填，至少 64 位随机字符串）
JWT_SECRET=generate-a-random-string-at-least-64-characters-long-for-security

# ==================== 可选配置 ====================
POSTGRES_DB=snake_game
POSTGRES_USER=snake_user
JWT_EXPIRES_IN=7d
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100
